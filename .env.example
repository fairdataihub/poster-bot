# posterbot configuration — copy to .env, fill in, chmod 600.
# .env is gitignored; never commit real credentials.
# docker compose reads this file automatically (portable/laptop deploy).

# --- ports (published to 127.0.0.1 only) ---
POSTERBOT_DB_PORT=5445
POSTERBOT_API_PORT=8722
POSTERBOT_LLM_PORT=27434

# --- database ---
POSTERBOT_DB_NAME=posters
POSTERBOT_DB_USER=posterbot_ro
# generate long random strings, e.g. openssl rand -base64 24 | tr -d '/+=' | head -c 32
POSTERBOT_PG_SUPER_PASSWORD=change-me
POSTERBOT_OWNER_PASSWORD=change-me
POSTERBOT_RO_PASSWORD=change-me

# --- chat model (served by the local ollama container) ---
# llama3.2:3b (~4GB VRAM) fits an 8GB laptop with headroom.
# Tight on VRAM? use llama3.2:1b (~1.5GB). The 4090 host can go up to ~13B.
LLM_MODEL=llama3.2:3b

# --- public exposure only (leave empty for local/laptop use) ---
# When set, /api/chat requires this code. Set before exposing via a relay VPS.
EVENT_CODE=
