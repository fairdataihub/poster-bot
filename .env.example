# posterbot configuration — copy to .env, fill in real values, chmod 600.
# .env is gitignored; never commit real credentials.

# loopback ports (pick free ones for your machine)
POSTERBOT_DB_PORT=5445
POSTERBOT_API_PORT=8722
POSTERBOT_LLM_PORT=27434

# postgres credentials (generate long random strings)
POSTERBOT_PG_SUPER_PASSWORD=change-me
POSTERBOT_OWNER_PASSWORD=change-me
POSTERBOT_RO_PASSWORD=change-me

# local chat model served by the dedicated ollama instance
LLM_MODEL=qwen3:4b

# optional shared code required for /api/chat when publicly exposed (empty = disabled)
EVENT_CODE=
